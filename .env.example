# Dev server port (also set in package.json scripts)
PORT=3100

# Локально: docker compose up -d  →  npm run db:push && npm run db:seed
DATABASE_URL="postgresql://sport:sport@localhost:5433/sport_app"

# Прод (Neon): https://neon.tech — для Vercel бери Pooled connection string
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# BotFather → your bot token
BOT_TOKEN="123456:ABC-DEF..."

# Шаринг программ через Telegram deep link (?startapp=share_<id>).
# Достаточно username бота: без short name открывается ОСНОВНОЙ Mini App
# бота — t.me/<bot>?startapp=... (работает, если у бота настроена кнопка-меню
# с Web App). Если задать и short name — используется named Direct Link
# t.me/<bot>/<app>?startapp=... (создаётся через BotFather /newapp).
# Если NEXT_PUBLIC_BOT_USERNAME не задан — шаринг падает на обычный web-URL.
NEXT_PUBLIC_BOT_USERNAME="your_bot_username"   # без @, обязательно
# NEXT_PUBLIC_MINIAPP_NAME="app"               # опционально: short name из /newapp

ANTHROPIC_API_KEY=your_anthropic_key_here
TOGETHER_API_KEY=your_together_key_here
OPENAI_API_KEY=your_openai_key_here
